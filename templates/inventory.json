  "scripts": [
   {
    "code": "if (ctx.event==='before_create' \u0026\u0026 ctx.record.product) {\n  var p = gloud.records.get(ctx.record.product);\n  if (p \u0026\u0026 p.stock \u003c ctx.record.qty) gloud.fail('Недостатньо на складі: '+p.name+' (залишок '+p.stock+')');\n}",
    "created_at": "2026-06-04 22:35:47",
    "description": "",
    "enabled": 1,
    "id": 1,
    "kind": "trigger",
    "name": "Перевірка залишку",
    "updated_at": "2026-06-04 22:35:47"
   },
   {
    "code": "if (ctx.event==='after_create' \u0026\u0026 ctx.record.product) {\n  var p = gloud.records.get(ctx.record.product);\n  if (p) gloud.records.update(p.id, { stock: p.stock - ctx.record.qty });\n}",
    "created_at": "2026-06-04 22:35:47",
    "description": "",
    "enabled": 1,
    "id": 2,
    "kind": "trigger",
    "name": "Списання залишку",
    "updated_at": "2026-06-04 22:35:47"
   },
   {
    "code": "var all = gloud.query('products').all();\nvar low = all.filter(function(p){ return p.stock \u003c= p.min_stock; });\nif (low.length) gloud.telegram.send('warehouse', '⚠️ Поповнити: '+low.map(function(p){return p.name;}).join(', '));",
    "created_at": "2026-06-04 22:35:47",
    "description": "",
    "enabled": 1,
    "id": 3,
    "kind": "batch",
    "name": "Алерт низького залишку",
    "updated_at": "2026-06-04 22:35:47"
   }
