  "scripts": [
   {
    "code": "if (ctx.event==='after_update' && ctx.record.stage==='Виграно' && ctx.old.stage!=='Виграно') {\n  gloud.telegram.send('sales', '🏆 Угоду виграно: <b>'+ctx.record.title+'</b> на суму '+ctx.record.amount);\n}",
    "created_at": "2026-06-04 22:35:47",
    "description": "",
    "enabled": 1,
    "id": 1,
    "kind": "trigger",
    "name": "Сповіщення про виграш",
    "updated_at": "2026-06-04 22:35:47"
   },
   {
    "code": "var rows = gloud.table({type:'deals', group_by:'stage', metric_fn:'sum', metric_field:'amount'});\nvar body = rows.map(function(r){return r.label+': ₴'+r.value;}).join('\\n');\ngloud.telegram.send('sales', '<b>Дайджест угод</b>\\n'+body);",
    "created_at": "2026-06-04 22:35:47",
    "description": "",
    "enabled": 1,
