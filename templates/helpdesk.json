   {
    "code": "var today = gloud.now().substring(0,10);\nvar overdue = gloud.query('tickets').where('status','neq','Закрита').where('due','lt',today).all();\nif (overdue.length) gloud.telegram.send('support-alerts', '⚠️ Прострочено заявок: '+overdue.length);",
