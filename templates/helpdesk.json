    "enabled": 1,
    "id": 2,
    "kind": "batch",
    "name": "Заявка з сайту (webhook)",
    "updated_at": "2026-06-04 22:35:47"
   },
   {
    "code": "if (ctx.event==='before_create' \u0026\u0026 !ctx.record.agent) {\n  var a = gloud.query('agents').where('team','eq','L1').first();\n  if (a) return { agent: a.id };\n}",
    "created_at": "2026-06-04 22:35:47",
    "description": "",
    "enabled": 1,
    "id": 3,
    "kind": "trigger",
    "name": "Авто-призначення L1",
    "updated_at": "2026-06-04 22:35:47"
   },
   {
    "code": "if (ctx.event==='after_update' \u0026\u0026 ctx.record.status==='Закрита' \u0026\u0026 ctx.old.status!=='Закрита' \u0026\u0026 ctx.record.requester_email) {\n  gloud.email.send(ctx.record.requester_email, 'Вашу заявку закрито', 'Дякуємо за звернення!');\n}",
    "created_at": "2026-06-04 22:35:47",
