  "scripts": [
   {
    "code": "if (ctx.text==='/new') { bot.setState('await_subject'); bot.reply('Опишіть проблему:'); }\nelse if (ctx.state==='await_subject') { var t = gloud.records.create('tickets', { subject: ctx.text, status:'Нова', priority:3 }); bot.setState(''); bot.reply('Заявку #'+t.num+' створено ✅'); }\nelse { bot.reply('Команди: /new — нова заявка'); }",
    "created_at": "2026-06-04 22:35:47",
    "description": "",
    "enabled": 1,
    "id": 1,
    "kind": "bot",
    "name": "Бот підтримки",
    "updated_at": "2026-06-04 22:35:47"
   },
   {
    "code": "gloud.records.create('tickets', { subject: ctx.params.subject || 'Без теми', requester_email: ctx.params.email || '', status:'Нова', priority:3 });\ngloud.output({ ok:true });",
