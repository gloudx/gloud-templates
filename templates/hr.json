  "scripts": [
   {
    "code": "if (ctx.event==='before_update' \u0026\u0026 ctx.record.status==='Узгоджено' \u0026\u0026 ctx.old.status!=='Узгоджено') {\n  var emp = gloud.records.get(ctx.record.employee);\n  if (emp \u0026\u0026 ctx.record.days \u003e emp.vacation_days) gloud.fail('Недостатньо днів відпустки у '+emp.name);\n}",
    "created_at": "2026-06-04 22:35:47",
    "description": "",
    "enabled": 1,
    "id": 1,
    "kind": "trigger",
    "name": "Перевірка днів відпустки",
    "updated_at": "2026-06-04 22:35:47"
   },
   {
    "code": "var md = gloud.now().substring(5,10);\nvar all = gloud.query('staff').where('status','neq','Звільнений').all();\nvar today = all.filter(function(e){ return (e.birthday||'').substring(5,10)===md; });\ntoday.forEach(function(e){ gloud.telegram.send('hr', '🎂 Сьогодні ДН у \u003cb\u003e'+e.name+'\u003c/b\u003e!'); });",
    "created_at": "2026-06-04 22:35:47",
