    "code": "if (ctx.event==='after_update' \u0026\u0026 ctx.record.status==='Опубліковано' \u0026\u0026 ctx.old.status!=='Опубліковано') {\n  gloud.http.post('https://hooks.example.com/publish', { title: ctx.record.title, link: ctx.record.link });\n}",
