   {
    "code": "var rows = gloud.table({type:'posts', group_by:'status', metric_fn:'count'});\nvar body = rows.map(function(r){return r.label+': '+r.value;}).join('\\n');\ngloud.telegram.send('smm', '\u003cb\u003eКонтент-план\u003c/b\u003e\\n'+body);",
