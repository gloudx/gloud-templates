    "scripts": [
      {
        "id": 1,
        "name": "Сповіщення в канал про нову статтю",
        "description": "Демо «Каналів»: на публікацію статті постить картку в чат-канал через gloud.channels.post.",
        "code": "// Демо: постить у чат-канал при публікації статті (фіча «Канали», gloud.channels.*).\n// Після імпорту: Налаштування → Канали — створіть канал 'news' і бота 'site-bot',\n// прив'яжіть бота до каналу. Без цього просто запишеться в лог (стаття все одно створиться).\ntry {\n  if (ctx.record.published) {\n    gloud.channels.post('news', '\\uD83D\\uDCF0 Нова стаття: ' + (ctx.record.title || ''), { bot: 'site-bot' });\n  }\n} catch (e) {\n  gloud.log('channel notify skipped (створіть канал news + бота site-bot): ' + e);\n}",
        "kind": "trigger",
        "enabled": 1,
        "created_at": "2026-06-13 12:00:00",
        "updated_at": "2026-06-13 12:00:00"
      }
    ],
