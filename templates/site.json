    "value_num": null,
    "value_ref": null
   },
   {
    "id": 21,
    "record_id": 4,
    "field_id": 3,
    "value_text": "Поки не готово.",
    "value_num": null,
    "value_ref": null
   },
   {
    "id": 22,
    "record_id": 4,
    "field_id": 4,
    "value_text": "<p>Чернетка — не повинна з'являтися на сайті.</p>",
    "value_num": null,
    "value_ref": null
   },
   {
    "id": 23,
