    "value_text": null,
    "value_num": 1,
    "value_ref": null
   },
   {
    "id": 19,
    "record_id": 4,
    "field_id": 1,
    "value_text": "Чернетка майбутньої статті",
    "value_num": null,
    "value_ref": null
   },
   {
    "id": 20,
    "record_id": 4,
    "field_id": 2,
