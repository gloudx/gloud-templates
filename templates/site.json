  "schema_values": [
   {
    "id": 1,
    "record_id": 1,
    "field_id": 1,
    "value_text": "Запуск нашого сервісу",
    "value_num": null,
    "value_ref": null
   },
   {
    "id": 2,
    "record_id": 1,
    "field_id": 2,
    "value_text": "launch",
    "value_num": null,
    "value_ref": null
   },
   {
    "id": 3,
    "record_id": 1,
    "field_id": 3,
    "value_text": "Ми раді оголосити про офіційний старт.",
    "value_num": null,
    "value_ref": null
   },
   {
    "id": 4,
    "record_id": 1,
    "field_id": 4,
    "value_text": "<p>Сьогодні ми <strong>офіційно запускаємо</strong> наш сервіс. Дякуємо всім, хто був із нами на шляху до цього дня.</p><p>Попереду — багато оновлень.</p>",
    "value_num": null,
    "value_ref": null
   },
   {
    "id": 5,
    "record_id": 1,
    "field_id": 6,
    "value_text": "2026-05-10",
    "value_num": null,
    "value_ref": null
   },
   {
    "id": 6,
    "record_id": 1,
    "field_id": 7,
    "value_text": null,
    "value_num": 1,
    "value_ref": null
   },
   {
    "id": 7,
    "record_id": 2,
    "field_id": 1,
    "value_text": "5 порад для початківців",
    "value_num": null,
    "value_ref": null
   },
   {
    "id": 8,
    "record_id": 2,
    "field_id": 2,
    "value_text": "5-porad",
    "value_num": null,
    "value_ref": null
   },
   {
    "id": 9,
    "record_id": 2,
    "field_id": 3,
    "value_text": "Короткий гайд, щоб швидко розібратися.",
    "value_num": null,
    "value_ref": null
   },
   {
    "id": 10,
    "record_id": 2,
    "field_id": 4,
    "value_text": "<p>Ось наші головні поради:</p><ol><li>Почніть з малого.</li><li>Читайте документацію.</li><li>Не бійтеся експериментувати.</li><li>Питайте спільноту.</li><li>Робіть регулярні бекапи.</li></ol>",
    "value_num": null,
    "value_ref": null
   },
   {
    "id": 11,
    "record_id": 2,
    "field_id": 6,
    "value_text": "2026-05-15",
    "value_num": null,
    "value_ref": null
   },
   {
    "id": 12,
    "record_id": 2,
    "field_id": 7,
    "value_text": null,
    "value_num": 1,
    "value_ref": null
   },
   {
    "id": 13,
    "record_id": 3,
    "field_id": 1,
    "value_text": "Оновлення версії 2.0",
    "value_num": null,
    "value_ref": null
   },
   {
    "id": 14,
    "record_id": 3,
    "field_id": 2,
    "value_text": "v2-update",
    "value_num": null,
    "value_ref": null
   },
   {
    "id": 15,
    "record_id": 3,
    "field_id": 3,
    "value_text": "Що нового у великому релізі.",
    "value_num": null,
    "value_ref": null
   },
   {
    "id": 16,
    "record_id": 3,
    "field_id": 4,
    "value_text": "<p>Версія 2.0 приносить новий редактор, темну тему та пришвидшення завантаження сторінок удвічі.</p>",
    "value_num": null,
    "value_ref": null
   },
   {
    "id": 17,
    "record_id": 3,
    "field_id": 6,
    "value_text": "2026-05-20",
    "value_num": null,
    "value_ref": null
   },
   {
    "id": 18,
